# ═══════════════════════════════════════════
#   KEYCEBET — Variables d'environnement
#   Copier ce fichier en .env et remplir les valeurs
#   NEVER commit .env — only .env.example
# ═══════════════════════════════════════════

# ─── BASE DE DONNÉES ───
POSTGRES_PASSWORD=change_me_strong_password

# ─── JWT ───
# Générer : openssl rand -base64 64
JWT_SECRET=change_me_in_production_at_least_256_bits_long_key
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ─── COMPTE ADMIN ───
ADMIN_EMAIL=ton_email@exemple.cm
ADMIN_PASSWORD=TonMotDePasseAdmin!

# ─── API PAIEMENT (AMI 1) ───
PAYMENT_API_KEY=
PAYMENT_API_URL=

# ─── API SPORTS (AMI 2) ───
SPORTS_API_KEY=
SPORTS_API_URL=